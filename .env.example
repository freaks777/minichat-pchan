# RP Standalone 設定ファイル
# backend/ の親ディレクトリに置く。起動時に自動読込。
# コピーして .env を作成し、使用するAPIキーを設定してください。

# ── APIキー（config.yaml の ${VAR} 形式で参照） ──
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=
OPENCODE_API_KEY=

# ── mail 通知用 (watchdog エスカレーション) ──
GMAIL_USER=
GMAIL_APP_PASSWORD=
